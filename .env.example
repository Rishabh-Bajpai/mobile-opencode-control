APP_ENV=development
APP_SECRET_KEY=change-me
APP_PASSWORD=opencode
DATABASE_URL=sqlite:///backend/data/app.db
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173
FRONTEND_ALLOWED_HOSTS=localhost,127.0.0.1
OPENCODE_CORS_ORIGINS=http://localhost:5173
ENABLE_CORS=true
SCHEDULER_POLL_INTERVAL_SECONDS=20
TASK_RUN_RETENTION_DAYS=30

OPENCODE_BASE_URL=http://127.0.0.1:4096
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=

VOICE_PROVIDER_MODE=auto

# External OpenAI-compatible voice endpoints (optional)
TTS_BASE_URL=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_API_KEY=

STT_BASE_URL=
STT_MODEL=whisper-1
STT_API_KEY=

# Built-in CPU voice defaults (used in builtin mode, or auto when external is not configured)
BUILTIN_STT_MODEL=small.en
BUILTIN_STT_COMPUTE_TYPE=int8
BUILTIN_STT_DEVICE=cpu
BUILTIN_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
BUILTIN_TTS_SPEAKER=
BUILTIN_TTS_LANGUAGE=

# Optional default root path shown during project creation
DEFAULT_PROJECT_ROOT=
